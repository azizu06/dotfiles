# Brewfile — system dependencies for this dotfiles environment.
# Install everything at once:  brew bundle   (run from this directory)
#
# Note: cmux (manaflow-ai) is a standalone app, NOT on Homebrew — install it
# separately. It BUNDLES Ghostty (the terminal), so there is no separate ghostty
# cask here; this repo only carries the ghostty/cmux *config*.

brew "neovim"            # the editor
brew "ripgrep"           # fast search (Telescope, cmux in-app search)
brew "fd"                # fast file finder (Telescope)
brew "lazygit"           # git TUI used from inside nvim
brew "tree-sitter-cli"   # syntax parsers for nvim

cask "font-jetbrains-mono-nerd-font"  # font + icon glyphs LazyVim needs
